<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
        <field>Requested_Credit_Limit__c</field>
        <field>Approved_Amount__c</field>
        <field>Financial_Product__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>franco.sotelogomez@resourceful-badger-n8xmfb.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <description>Paso de aprobación donde el Analista evalúa oportunidades con línea de crédito mayor a 3000.</description>
        <label>Aprobación del Analista</label>
        <name>Aprobacion_Analista</name>
    </approvalStep>
    <description>Proceso de aprobación para oportunidades cuya línea de crédito solicitada supera los 3000 soles y requieren validación por parte del Analista.</description>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Opportunity.Requested_Credit_Limit__c</field>
            <operation>greaterThan</operation>
            <value>3000</value>
        </criteriaItems>
        <criteriaItems>
            <field>Opportunity.StageName</field>
            <operation>equals</operation>
            <value>Evaluación</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Aprobar</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Pasar_a_Contrato</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Rechazar_Oportunidad</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>Aprobación de Línea de Crédito</label>
    <processOrder>1</processOrder>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
